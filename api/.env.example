# =============================================================================
# Menu COGS — API Environment Variables (example)
# Copy to `api/.env` and fill in values for your environment.
# =============================================================================

# -----------------------------------------------------------------------------
# Core runtime
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# Config store (local Postgres — holds encrypted DB connection + AI keys)
# -----------------------------------------------------------------------------
# The API keeps connection settings and API keys in a dedicated local Postgres
# database. This lets admins switch between local and standalone (AWS RDS) DB
# targets from the UI at /configuration → Database without editing .env.
#
# CONFIG_STORE_SECRET is REQUIRED. It is the 32-byte master key used to
# encrypt passwords and API keys at rest (AES-256-GCM). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONFIG_STORE_SECRET=replace-with-64-hex-chars

# Config-store connection (defaults to localhost:5432/mcogs_config).
# The mcogs_config database must exist before starting the API:
#   createdb mcogs_config
# CONFIG_DB_HOST=localhost
# CONFIG_DB_PORT=5432
# CONFIG_DB_NAME=mcogs_config
# CONFIG_DB_USER=mcogs
# CONFIG_DB_PASSWORD=changeme

# -----------------------------------------------------------------------------
# Database — choose LOCAL or STANDALONE mode
# -----------------------------------------------------------------------------
# The first time the API starts, it seeds the config store from the DB_*
# variables below. After that, the config store is authoritative — edit the
# connection via the Settings → Database tab in the UI, not here. The DB_*
# vars remain a break-glass fallback if the config store is unreachable.
#
# DB_MODE selects how the API connects to PostgreSQL:
#   • local       → database runs on the same host as the API (default)
#   • standalone  → database runs on a separate host (e.g. AWS RDS,
#                   AWS Lightsail managed DB, or any remote PostgreSQL)
#
# When DB_MODE is unset it is inferred automatically:
#   • DB_CONNECTION_STRING / DATABASE_URL set → standalone
#   • DB_HOST is a non-loopback hostname      → standalone
#   • otherwise                                → local
DB_MODE=local

# -----------------------------------------------------------------------------
# Option A — individual connection fields (works for both modes)
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mcogs
DB_USER=mcogs
DB_PASSWORD=changeme

# -----------------------------------------------------------------------------
# Option B — full PostgreSQL connection string (alternative to Option A)
# Either DB_CONNECTION_STRING or the legacy DATABASE_URL alias is accepted.
# Individual DB_* vars above, if also set, override fields from the URI
# (useful for rotating only the password without rewriting the URI).
# -----------------------------------------------------------------------------
# DB_CONNECTION_STRING=postgresql://mcogs:changeme@mcogs.abcdef1234.eu-west-2.rds.amazonaws.com:5432/mcogs

# -----------------------------------------------------------------------------
# SSL / TLS (recommended for standalone / AWS RDS)
# -----------------------------------------------------------------------------
# DB_SSL defaults:
#   • local      → OFF
#   • standalone → ON
# Override with DB_SSL=true|false
# DB_SSL=true
#
# DB_SSL_CA — optional path to a CA bundle for strict certificate verification.
# For AWS RDS, download the global bundle:
#   https://truststore.pki.rds.amazonaws.com/global/global-bundle.pem
# and point this at the file. When set, certificates are verified strictly.
# When unset, SSL still encrypts the connection but does not pin the cert.
# DB_SSL_CA=/etc/ssl/rds/global-bundle.pem
#
# DB_SSL_REJECT_UNAUTHORIZED — overrides cert-verification behaviour.
# Defaults to `true` when DB_SSL_CA is set, `false` otherwise.
# DB_SSL_REJECT_UNAUTHORIZED=true

# -----------------------------------------------------------------------------
# Pool tuning (optional)
# -----------------------------------------------------------------------------
# DB_POOL_MAX=10
# DB_IDLE_TIMEOUT_MS=30000
# DB_CONNECTION_TIMEOUT_MS=10000

# -----------------------------------------------------------------------------
# Example: standalone AWS RDS configuration
# -----------------------------------------------------------------------------
# DB_MODE=standalone
# DB_HOST=mcogs.abcdef1234.eu-west-2.rds.amazonaws.com
# DB_PORT=5432
# DB_NAME=mcogs
# DB_USER=mcogs
# DB_PASSWORD=<rds-password>
# DB_SSL=true
# DB_SSL_CA=/etc/ssl/rds/global-bundle.pem
