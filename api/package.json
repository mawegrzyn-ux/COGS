{
  "name": "menu-cogs-api",
  "version": "1.0.0",
  "description": "Menu COGS REST API — Node.js / Express / PostgreSQL",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "migrate": "node scripts/migrate.js",
    "migrate:data": "node scripts/import-data.js mcogs-export.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:setup": "node scripts/test-setup.js",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:schema": "vitest run test/schema",
    "validate:seed": "node scripts/validate-seed-import.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@aws-sdk/client-s3": "^3.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.8.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.12.0",
    "sharp": "^0.33.4",
    "isomorphic-dompurify": "^2.21.0",
    "node-cron": "^3.0.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "mysql2": "^3.10.0",
    "nodemon": "^3.1.4",
    "vitest": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0",
    "supertest": "^7.0.0"
  }
}
